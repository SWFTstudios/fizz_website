    "gsap": "^3.15.0",
    "lottie-web": "^5.13.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250219.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.21.0",
    "prettier": "^3.4.2",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.7.3",
